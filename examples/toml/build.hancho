#-------------------------------------------------------------------------------
# examples/toml/build.hancho

import hancho

tools = hancho.load("{hancho_dir}/tools/tools_base.hancho")

toml_parser_lib = hancho.task(
    tools.cpp_lib,
    in_srcs = "toml_parser.cpp",
    out_lib = "toml_parser.a",
)

toml_test = hancho.task(
    tools.cpp_test,
    in_srcs = "toml_test.cpp",
    in_libs = toml_parser_lib,
    out_bin = "toml_test",
    task_cwd = "{repo_dir}/examples/toml",
)
