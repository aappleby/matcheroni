# matcheroni/build.hancho

hancho.context.includes = "{repo_dir}"
hancho.context.test_dir = "{repo_dir}"

hancho.base_rules = hancho.repo("{hancho_dir}//base_rules.hancho")

hancho.c_lexer  = hancho.load("examples/c_lexer/build.hancho")
hancho.c_parser = hancho.load("examples/c_parser/build.hancho")

json     = hancho.load("examples/json/build.hancho")
regex    = hancho.load("examples/regex/build.hancho")
toml     = hancho.load("examples/toml/build.hancho")

tutorial = hancho.load("examples/tutorial/test.hancho")

